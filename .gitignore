# Local Terraform directories
.terraform/
.terraform.lock.hcl

# Terraform state files (sensitive)
terraform.tfstate
terraform.tfstate.backup
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Variable files containing secrets
*.tfvars
*.tfvars.json
*.auto.tfvars
*.auto.tfvars.json

# Override files (local only)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration
.terraformrc
terraform.rc